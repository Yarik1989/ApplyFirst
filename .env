# Scheduler
POLL_INTERVAL_MINUTES=5
MAX_APPLIES_PER_DAY=15
MIN_ATS_SCORE_THRESHOLD=60

# Notifications (anti-flag random delay)
NOTIFY_DELAY_MIN_SECONDS=120
NOTIFY_DELAY_MAX_SECONDS=480

# Job search
SEARCH_KEYWORDS=Registered Nurse,RN,Nurse,Med-Surg,Acute Care,Neurology
SEARCH_LOCATION=Roseville CA
SEARCH_RADIUS_MILES=25

# Sacramento-metro city whitelist (comma-separated, case-insensitive)
# Used to filter scraped jobs to ~25mi of Roseville when source-side filtering is unavailable
SEARCH_LOCAL_CITIES=Roseville,Rocklin,Lincoln,Loomis,Granite Bay,Citrus Heights,Fair Oaks,Orangevale,Carmichael,Antelope,Rio Linda,North Highlands,Arden-Arcade,Sacramento,Folsom,Rancho Cordova,Elk Grove,West Sacramento,Davis,Woodland,Auburn

# Timezone for "posted today" interpretation (job boards report dates in local time)
SEARCH_TIMEZONE=America/Los_Angeles

# Database
DATABASE_PATH=./data/applyfirst.db

JOBSPY_HOURS_OLD=24
